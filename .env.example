# HTTP server
PORT=3000

# DB
POSTGRES_USER=root
POSTGRES_PASSWORD=1234
POSTGRES_DB=senappen
POSTGRES_PORT=5432

# Replace each placeholder in the connection string with the corresponding value.
# Do NOT interpolate env vars directly inside the string. Example:
# DATABASE_URL="postgresql://root:1234@localhost:5432/senappen?schema=public"
DATABASE_URL="postgresql://root:1234@localhost:5432/senappen?schema=public"

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT=6379

# Worker
WORKER_CONCURRENCY=5

# Local storage (provisório) — videos are stored at storage/videos/
# Leave AZURE_* unset to keep using local disk.

# Azure Blob Storage (Section 3b — set these to migrate away from local storage)
# AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
# AZURE_STORAGE_CONTAINER="parlatorios-videos"

# Mock data
USE_MOCK_DATA=true