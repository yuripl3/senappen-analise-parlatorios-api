# HTTP server
PORT=3000

# ── Azure Cosmos DB ──────────────────────────────────────────────────────────
# Leave COSMOS_ENDPOINT/COSMOS_KEY empty to rely on USE_MOCK_DATA=true
# COSMOS_ENDPOINT="https://localhost:8081"
# COSMOS_KEY="<your-cosmos-key>"
COSMOS_DATABASE=senappen

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Azure Blob Storage (optional — falls back to local storage) ──────────────
# AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
# AZURE_STORAGE_CONTAINER="parlatorios-videos"

# ── Azure Service Bus (optional — falls back to mock in dev) ─────────────────
# SERVICE_BUS_CONNECTION_STRING="Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=..."

# ── Azure Key Vault (optional — falls back to .env) ─────────────────────────
# KEY_VAULT_URL="https://<vault-name>.vault.azure.net/"

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY="sk-..."

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Feature flags ────────────────────────────────────────────────────────────
USE_MOCK_DATA=true
USE_MOCK_AI=true
